{
  "name": "tinylicious",
  "version": "0.4.0",
  "description": "Tiny, test implementation of the routerlicious reference service",
  "homepage": "https://fluidframework.com",
  "repository": "https://github.com/microsoft/FluidFramework",
  "license": "MIT",
  "author": "Microsoft and contributors",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "bin": "dist/index.js",
  "scripts": {
    "build": "concurrently npm:build:compile npm:lint",
    "build:compile": "npm run tsc",
    "build:full": "npm run build",
    "build:full:compile": "npm run build:compile",
    "clean": "rimraf dist lib *.tsbuildinfo *.build.log",
    "eslint": "eslint --format stylish src",
    "eslint:fix": "eslint --format stylish src --fix",
    "lint": "npm run eslint",
    "lint:fix": "npm run eslint:fix",
    "start": "node dist/index.js",
    "start:debug": "node --inspect=0.0.0.0:9229 dist/index.js",
    "test": "npm run test:mocha",
    "test:mocha": "mocha --recursive dist/test -r node_modules/@fluidframework/mocha-test-setup --unhandled-rejections=strict",
    "tsc": "tsc"
  },
  "dependencies": {
    "@fluidframework/common-definitions": "^0.20.0",
    "@fluidframework/common-utils": "^0.30.0",
    "axios": "^0.21.1",
    "body-parser": "^1.17.1",
    "compression": "^1.7.2",
    "cookie-parser": "^1.4.3",
    "cors": "^2.8.4",
    "debug": "^4.1.1",
    "detect-port": "^1.3.0",
    "double-ended-queue": "^2.1.0-0",
    "express": "^4.16.3",
    "ioredis": "^4.24.2",
    "isomorphic-git": "^0.72.1",
    "json-stringify-safe": "^5.0.1",
    "jsrsasign": "^10.2.0",
    "jwt-decode": "^3.0.0",
    "lodash": "^4.17.21",
    "nconf": "^0.11.0",
    "notepack.io": "^2.3.0",
    "semver": "^6.3.0",
    "socket.io": "^2.4.1",
    "socket.io-redis": "^5.2.0",
    "uuid": "^8.3.1",
    "winston": "^3.1.0"
  },
  "devDependencies": {
    "@fluidframework/build-common": "^0.22.0",
    "@fluidframework/eslint-config-fluid": "^0.23.0",
    "@fluidframework/mocha-test-setup": "^0.27.0",
    "@microsoft/api-extractor": "^7.13.1",
    "@types/compression": "0.0.33",
    "@types/cookie-parser": "^1.4.1",
    "@types/cors": "^2.8.4",
    "@types/detect-port": "^1.3.0",
    "@types/double-ended-queue": "^2.1.0",
    "@types/json-stringify-safe": "^5.0.0",
    "@types/jsrsasign": "^8.0.8",
    "@types/jwt-decode": "^2.2.1",
    "@types/lodash": "^4.14.149",
    "@types/mocha": "^8.2.2",
    "@types/node": "^12.19.0",
    "@types/semver": "^6.2.0",
    "@types/socket.io": "^2.1.4",
    "@types/uuid": "^8.3.0",
    "@typescript-eslint/eslint-plugin": "~4.14.0",
    "@typescript-eslint/eslint-plugin-tslint": "~2.16.0",
    "@typescript-eslint/parser": "~4.14.0",
    "concurrently": "^5.2.0",
    "eslint": "~7.18.0",
    "eslint-plugin-eslint-comments": "~3.2.0",
    "eslint-plugin-import": "~2.22.1",
    "eslint-plugin-no-null": "~1.0.2",
    "eslint-plugin-prefer-arrow": "~1.2.2",
    "eslint-plugin-react": "~7.22.0",
    "eslint-plugin-unicorn": "~26.0.1",
    "mocha": "^8.4.0",
    "rimraf": "^2.6.2",
    "ts-node": "^8.6.2",
    "typescript": "~4.1.3"
  },
  "engines": {
    "node": ">=12.17.0"
  }
